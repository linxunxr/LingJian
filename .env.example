# ============================================================
# Tauri 自动更新签名密钥（构建安装包时使用）
# 生成方式：npx tauri signer generate --password "<你的密码>"
# ============================================================

# 私钥（base64 编码的长字符串）
TAURI_SIGNING_PRIVATE_KEY=

# 私钥密码（生成密钥时设置的）
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=


# ============================================================
# 腾讯云 COS（自动更新镜像源，CI 同步安装包到 COS）
# 在腾讯云控制台创建 CAM 子账号获取，仅需 COS 读写权限
# 这些值需配置到 GitHub Secrets，非本地环境变量
# ============================================================

# CAM 子账号 SecretId
COS_SECRET_ID=

# CAM 子账号 SecretKey
COS_SECRET_KEY=

# ============================================================
# GitHub Secrets 配置清单（仓库 Settings → Secrets → Actions）
# ============================================================
# TAURI_SIGNING_PRIVATE_KEY        ← Tauri 签名私钥
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD ← Tauri 签名密码
# COS_SECRET_ID                    ← 腾讯云 CAM SecretId（COS 读写权限）
# COS_SECRET_KEY                   ← 腾讯云 CAM SecretKey
